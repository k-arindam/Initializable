{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/swiftsyntax\/swiftsyntax-by-example"]}],"metadata":{"categoryPathComponent":"Tutorial-Table-of-Contents","role":"project","category":"SwiftSyntax","title":"SwiftSyntax By Example"},"sections":[{"estimatedTimeInMinutes":15,"title":"SwiftSyntax By Example","content":[{"type":"paragraph","inlineContent":[{"text":"In this tutorial you’ll explore the SwiftSyntax API by writing a tool","type":"text"},{"text":" ","type":"text"},{"text":"that formats and sorts the import statements in a Swift file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ll start by using the Swift parser to parse code into a syntax tree."},{"type":"text","text":" "},{"type":"text","text":"Then you’ll use syntax transformation APIs to analyze the structure of"},{"type":"text","text":" "},{"type":"text","text":"the document. Finally, you’ll write out fully-formatted Swift code as"},{"type":"text","text":" "},{"type":"text","text":"output."}]}],"kind":"hero","chapter":"SwiftSyntax By Example"},{"tasks":[{"title":"Create a New Executable Package using SwiftSyntax","stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Open Xcode and choose File > New > Package, name your package"},{"type":"text","text":" "},{"type":"text","text":"“importformatter”, and choose a place for it on disk."}],"type":"paragraph"}],"caption":[],"code":null,"runtimePreview":null,"media":"importformatter-package-project.png","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Select the Package.swift file in the file navigator.","type":"text"}]}],"caption":[],"code":"Package.step1.swift","runtimePreview":null,"media":null,"type":"step"},{"code":"Package.step2.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Change the ","type":"text"},{"type":"codeVoice","code":".library"},{"text":" entry for ","type":"text"},{"type":"codeVoice","code":"importformatter"},{"text":" to a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".executable"},{"type":"text","text":" entry, and change the "},{"type":"codeVoice","code":".target"},{"type":"text","text":" entry to a"},{"type":"text","text":" "},{"code":".executableTarget","type":"codeVoice"},{"text":".","type":"text"}]}],"media":null,"caption":[{"inlineContent":[{"text":"The completed ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":" file should look","type":"text"},{"text":" ","type":"text"},{"text":"like this:","type":"text"}],"type":"paragraph"}],"runtimePreview":null}],"contentSection":[{"content":[{"inlineContent":[{"text":"Create a new executable package that uses SwiftSyntax.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"We’ll keep our formatter tool contained to the "},{"type":"codeVoice","code":"inputformatter.swift"},{"type":"text","text":" file"},{"type":"text","text":" "},{"type":"text","text":"generated by the package. You will not need to add any new files during"},{"type":"text","text":" "},{"type":"text","text":"this tutorial."}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Create-a-New-Executable-Package-using-SwiftSyntax"},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Open the "},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":" file created in the previous section."}],"type":"paragraph"}],"caption":[],"type":"step","media":null,"code":"Package.step2.swift","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Add the "},{"code":"swift-syntax","type":"codeVoice"},{"text":" package to the dependencies section of your","type":"text"},{"text":" ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":" file.","type":"text"}],"type":"paragraph"}],"media":null,"code":"Package.step3.swift","caption":[],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Add the "},{"type":"codeVoice","code":"SwiftSyntax"},{"type":"text","text":" and "},{"type":"codeVoice","code":"SwiftParser"},{"type":"text","text":" products as dependencies of"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"importformatter"},{"type":"text","text":" executable target."}],"type":"paragraph"}],"media":null,"code":"Package.step4.swift","caption":[],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"text":"Add a ","type":"text"},{"code":"macOS 10.15","type":"codeVoice"},{"text":" platform constraint to the ","type":"text"},{"code":"platforms","type":"codeVoice"},{"text":" section","type":"text"},{"text":" ","type":"text"},{"text":"of your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" file."}],"type":"paragraph"}],"media":null,"code":"Package.step5.swift","caption":[],"type":"step","runtimePreview":null}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"Configure your package and get started with a command line application.","type":"text"}]}]}],"anchor":"Configure-Your-Package","title":"Configure Your Package"},{"stepsSection":[{"caption":[],"code":"Formatter.step1.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"In the Xcode file navigator, select the ","type":"text"},{"code":"importformatter.swift","type":"codeVoice"},{"text":".","type":"text"}]}],"type":"step","media":null},{"caption":[],"code":"Formatter.step2.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Using the provided code, set up a bare-bones command line application","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"importformatter.swift","type":"codeVoice"},{"text":".","type":"text"}]}],"type":"step","media":null},{"caption":[],"code":"Formatter.step3.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an import of the "},{"type":"codeVoice","code":"SwiftSyntax"},{"type":"text","text":" and "},{"type":"codeVoice","code":"SwiftParser"},{"type":"text","text":" libraries in"},{"type":"text","text":" "},{"type":"codeVoice","code":"importformatter.swift"}]}],"type":"step","media":null},{"caption":[{"inlineContent":[{"type":"text","text":"At this point, your formatter tool is ready to run, even if it doesn’t"},{"type":"text","text":" "},{"type":"text","text":"actually format any code. Create a test "},{"type":"codeVoice","code":"swift"},{"text":" file pass it to the","type":"text"},{"text":" ","type":"text"},{"text":"formatter to make sure it gets printed to the console in Xcode. To","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"configure the arguments to a command line application, enter the scheme"},{"text":" ","type":"text"},{"text":"editor with Product > Scheme > Edit Scheme. Under the ‘Arguments’ tab","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you can provide the full path to your test Swift file."}],"type":"paragraph"}],"runtimePreview":null,"code":"Formatter.step4.swift","media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Call "},{"code":"Parser.parse","type":"codeVoice"},{"type":"text","text":" to parse the input file as a "},{"type":"codeVoice","code":"SourceFileSyntax"},{"text":" value.","type":"text"}],"type":"paragraph"}]},{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Small helper functions and helper types like these help make your"},{"text":" ","type":"text"},{"text":"Swift code easier to read and reason about.","type":"text"}]}],"media":null,"code":"Formatter.step5.swift","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Next, write a helper function that classifies code block"},{"type":"text","text":" "},{"type":"text","text":"items containing imports. To help keep track of the classified items,"},{"type":"text","text":" "},{"type":"text","text":"define an "},{"code":"Item","type":"codeVoice"},{"type":"text","text":" enum that has two cases: one for "},{"code":"import","type":"codeVoice"},{"type":"text","text":""},{"text":" ","type":"text"},{"type":"text","text":"declaration items and one for "},{"code":"other","type":"codeVoice"},{"type":"text","text":" items."}],"type":"paragraph"}],"type":"step"},{"caption":[{"type":"paragraph","inlineContent":[{"text":"The map sends the items with ","type":"text"},{"code":"ImportDeclSyntax","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"nodes to "},{"code":"Item.import","type":"codeVoice"},{"type":"text","text":" values, and all other items to "},{"code":"Item.other","type":"codeVoice"},{"type":"text","text":" values."}]}],"code":"Formatter.step6.swift","media":null,"content":[{"inlineContent":[{"type":"text","text":"To implement the item classifier, map over the "},{"code":"statements","type":"codeVoice"},{"text":" in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source file syntax node."}],"type":"paragraph"}],"type":"step","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"With the classifier function written, it’s time to implement the"},{"type":"text","text":" "},{"type":"text","text":"formatter itself. First, make sure that all of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"import"},{"type":"text","text":"s appear at the start of the source file. Swift provides a"},{"type":"text","text":" "},{"type":"text","text":"handy method to let us group a related set of statements together:"},{"type":"text","text":" "},{"code":"partition(by:)","type":"codeVoice"},{"text":". Calling this method on the classified ","type":"text"},{"type":"codeVoice","code":"items"},{"text":"","type":"text"},{"type":"text","text":" "},{"type":"text","text":"also returns the index that divides the "},{"type":"codeVoice","code":"import"},{"text":"s from the ","type":"text"},{"type":"codeVoice","code":"other"},{"text":" ","type":"text"},{"text":"statements, which will come in handy later.","type":"text"}],"type":"paragraph"}],"caption":[],"media":null,"code":"Formatter.step7.swift","runtimePreview":null,"type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"Next, sort the imports among each other by calling "},{"type":"codeVoice","code":"sort(by:)"},{"type":"text","text":" "},{"type":"text","text":"using the lexicographic comparison provided by Swift’s "},{"type":"codeVoice","code":"String"},{"text":".","type":"text"}],"type":"paragraph"}],"media":null,"code":"Formatter.step8.swift","runtimePreview":null,"type":"step","caption":[{"inlineContent":[{"text":"Notice that we don’t need to sort the entire array of statements, just","type":"text"},{"text":" ","type":"text"},{"text":"the imports. The call to ","type":"text"},{"type":"codeVoice","code":"partition(by:)"},{"text":" gave us precisely the range of","type":"text"},{"text":" ","type":"text"},{"text":"the statements  collection we actually need to sort!","type":"text"}],"type":"paragraph"}]},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that the array of items is sorted and everything is in"},{"type":"text","text":" "},{"type":"text","text":"the right position, modify the source file to actually use"},{"text":" ","type":"text"},{"text":"those statements. Call the ","type":"text"},{"type":"codeVoice","code":"map"},{"text":" method to extract the statements from","type":"text"},{"text":" ","type":"text"},{"text":"the array of items.","type":"text"}]}],"media":null,"code":"Formatter.step9.swift","runtimePreview":null},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Then use "},{"type":"codeVoice","code":"with(\\.statements, <#new statements#>)*"},{"text":" method to create a source file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that contains the extracted array of statements."}],"type":"paragraph"}],"code":"Formatter.step10.swift","type":"step","caption":[{"inlineContent":[{"text":"The syntax tree is immutable. The result of calling ","type":"text"},{"code":"with","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"always a copy of a syntax tree node with the specified child element","type":"text"},{"text":" ","type":"text"},{"text":"changed.","type":"text"}],"type":"paragraph"}],"media":null}],"title":"Getting Started with SwiftSyntax","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You’ll use SwiftSyntax to fill out the functionality of the formatter."},{"type":"text","text":" "},{"type":"text","text":"The tool sends its output to standard out by printing the syntax tree."},{"type":"text","text":" "},{"type":"text","text":"You should run the formatter on one or more test files while you follow"},{"type":"text","text":" "},{"type":"text","text":"this tutorial and observe the resulting output."}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Getting-Started-with-SwiftSyntax"},{"anchor":"Cleaning-Up-The-Syntax-Tree","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that you have the core of the formatter done, you’ll learn how to"},{"type":"text","text":" "},{"type":"text","text":"manipulate whitespace to clean up its output."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Syntax trees created with the Swift parser and SwiftSyntax provide"},{"type":"text","text":" "},{"type":"text","text":"a property called "},{"type":"emphasis","inlineContent":[{"type":"text","text":"source fidelity"}]},{"type":"text","text":". This means that all whitespace,"},{"type":"text","text":" "},{"type":"text","text":"comments, and even invisible bytes in the file are represented in the"},{"type":"text","text":" "},{"type":"text","text":"tree. Collectively, we refer to these entities as "},{"type":"emphasis","inlineContent":[{"type":"text","text":"trivia"}]},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this section, you’ll use methods provided by SwiftSyntax to manipulate"},{"type":"text","text":" "},{"type":"text","text":"the trivia attached to syntax nodes."}]}]}],"stepsSection":[{"runtimePreview":null,"type":"step","code":"Formatter.step10.swift","caption":[{"inlineContent":[{"text":"The imports of ","type":"text"},{"type":"codeVoice","code":"SwiftParser"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"SwiftSyntax"},{"text":" are jammed together with","type":"text"},{"text":" ","type":"text"},{"text":"no whitespace between them. The import of ","type":"text"},{"type":"codeVoice","code":"Foundation"},{"text":" has an extra","type":"text"},{"text":" ","type":"text"},{"text":"leading newline.","type":"text"}],"type":"paragraph"}],"media":null,"content":[{"inlineContent":[{"text":"The formatter is nearly complete, but there’s still a pretty nasty","type":"text"},{"text":" ","type":"text"},{"text":"set of bugs. Run the tool on the ","type":"text"},{"code":"importformatter.swift","type":"codeVoice"},{"text":" file itself","type":"text"},{"text":" ","type":"text"},{"text":"and observe its output carefully.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Normalize the whitespace of all the imports by calling the trivia"},{"type":"text","text":" "},{"type":"text","text":"manipulation functions "},{"type":"codeVoice","code":"with(\\.leadingTrivia, _:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"with(\\.trailingTrivia, _:)"},{"type":"text","text":" on import items."}],"type":"paragraph"}],"type":"step","caption":[{"inlineContent":[{"type":"text","text":"SwiftSyntax does not automatically format whitespace and trivia when"},{"type":"text","text":" "},{"type":"text","text":"items are moved around. SwiftSyntax provides a convenient way of"},{"type":"text","text":" "},{"type":"text","text":"manipulating whitespace by calling the"},{"type":"text","text":" "},{"type":"codeVoice","code":"with(\\.leadingTrivia, _:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"with(\\.trailingTrivia, _:)"},{"type":"text","text":" methods. By normalizing all"},{"type":"text","text":" "},{"type":"text","text":"of the whitespace to a single leading newline we can fix bug #1. And"},{"type":"text","text":" "},{"text":"by removing all trailing whitespace we can fix bug #2.","type":"text"}],"type":"paragraph"}],"media":null,"runtimePreview":null,"code":"Formatter.step11.swift"},{"code":"Formatter.step11.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"There’s still some work to do here, though. Because we replaced "},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"type":"text","text":" of"},{"type":"text","text":" "},{"type":"text","text":"the trivia, we’ve also removed any comments attached to the imports. As"},{"type":"text","text":" "},{"type":"text","text":"an added challenge, try to edit the trivia to preserve comments and only"},{"type":"text","text":" "},{"type":"text","text":"change whitespace."}]}],"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Check your progress. Try re-running the formatter on the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"importformatter.swift"},{"text":" file again. This time, notice that the import","type":"text"},{"text":" ","type":"text"},{"text":"statements are not just sorted, but have whitespace corrected and","type":"text"},{"text":" ","type":"text"},{"text":"normalized.","type":"text"}]}],"media":null}],"title":"Cleaning Up The Syntax Tree"}],"kind":"tasks"}],"identifier":{"url":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example","interfaceLanguage":"swift"},"kind":"project","hierarchy":{"reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents","modules":[{"reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents\/SwiftSyntax-By-Example","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Create-a-New-Executable-Package-using-SwiftSyntax"},{"kind":"task","reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Configure-Your-Package"},{"kind":"task","reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Getting-Started-with-SwiftSyntax"},{"kind":"task","reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Cleaning-Up-The-Syntax-Tree"}],"reference":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example"}]}],"paths":[["doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents\/$volume","doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents\/SwiftSyntax-By-Example"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"Package.step1.swift":{"content":["\/\/ swift-tools-version: 5.9","\/\/ The swift-tools-version declares the minimum version of Swift required to build this package.","","import PackageDescription","","let package = Package(","  name: \"importformatter\",","  products: [","    \/\/ Products define the executables and libraries a package produces, making them visible to other packages.","    .library(","      name: \"importformatter\",","      targets: [\"importformatter\"]","    )","  ],","  targets: [","    \/\/ Targets are the basic building blocks of a package, defining a module or a test suite.","    \/\/ Targets can depend on other targets in this package and products from dependencies.","    .target(","      name: \"importformatter\"","    ),","    .testTarget(","      name: \"importformatterTests\",","      dependencies: [\"importformatter\"]","    ),","  ]",")"],"fileName":"Package.swift","identifier":"Package.step1.swift","type":"file","highlights":[],"syntax":"swift","fileType":"swift"},"doc://com.apple.swift-syntax/tutorials/Tutorial-Table-of-Contents/SwiftSyntax-By-Example":{"url":"\/tutorials\/tutorial-table-of-contents\/swiftsyntax-by-example","title":"SwiftSyntax By Example","type":"topic","role":"article","kind":"article","identifier":"doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents\/SwiftSyntax-By-Example","abstract":[]},"Formatter.step6.swift":{"type":"file","highlights":[{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47},{"line":48},{"line":49}],"fileName":"importformatter.swift","content":["import Foundation","import SwiftParser","import SwiftSyntax","","@main struct ImportFormatter {","  static func main() {","    guard CommandLine.arguments.count == 2 else {","      print(\"Not enough arguments!\")","      return","    }","","    let filePath = CommandLine.arguments[1]","    guard FileManager.default.fileExists(atPath: filePath) else {","      print(\"File doesn't exist at path: \\(filePath)\")","      return","    }","","    guard let file = try? String(contentsOfFile: filePath) else {","      print(\"File at path isn't readable: \\(filePath)\")","      return","    }","","    let formattedFile = ImportFormatter().formatImports(in: file)","    print(formattedFile)","  }","","  func formatImports(in file: String) -> SourceFileSyntax {","    let sourceFile = Parser.parse(source: file)","    var items = classifyItems(in: sourceFile)","    return sourceFile","  }","","  enum Item {","    case `import`(ImportDeclSyntax, CodeBlockItemSyntax)","    case other(CodeBlockItemSyntax)","  }","","  func classifyItems(in file: SourceFileSyntax) -> [Item] {","    file","      .statements","      .map { statement in","        if case .decl(let decl) = statement.item,","          let `import` = decl.as(ImportDeclSyntax.self)","        {","          return .import(`import`, statement)","        } else {","          return .other(statement)","        }","      }","  }","}"],"syntax":"swift","identifier":"Formatter.step6.swift","fileType":"swift"},"Formatter.step3.swift":{"syntax":"swift","fileName":"importformatter.swift","identifier":"Formatter.step3.swift","fileType":"swift","content":["import Foundation","import SwiftParser","import SwiftSyntax","","@main struct ImportFormatter {","  static func main() {","    guard CommandLine.arguments.count == 2 else {","      print(\"Not enough arguments!\")","      return","    }","","    let filePath = CommandLine.arguments[1]","    guard FileManager.default.fileExists(atPath: filePath) else {","      print(\"File doesn't exist at path: \\(filePath)\")","      return","    }","","    guard let file = try? String(contentsOfFile: filePath) else {","      print(\"File at path isn't readable: \\(filePath)\")","      return","    }","","    let formattedFile = ImportFormatter().formatImports(in: file)","    print(formattedFile)","  }","","  func formatImports(in file: String) -> SourceFileSyntax {","    \/* Formatter here *\/","  }","}"],"type":"file","highlights":[{"line":2},{"line":3}]},"doc://com.apple.swift-syntax/tutorials/SwiftSyntax/SwiftSyntax-By-Example#Create-a-New-Executable-Package-using-SwiftSyntax":{"kind":"section","abstract":[{"text":"In this tutorial you’ll explore the SwiftSyntax API by writing a tool","type":"text"},{"text":" ","type":"text"},{"text":"that formats and sorts the import statements in a Swift file.","type":"text"}],"url":"\/tutorials\/swiftsyntax\/swiftsyntax-by-example#Create-a-New-Executable-Package-using-SwiftSyntax","type":"section","title":"Create a New Executable Package using SwiftSyntax","identifier":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Create-a-New-Executable-Package-using-SwiftSyntax","role":"pseudoSymbol"},"doc://com.apple.swift-syntax/tutorials/SwiftSyntax/SwiftSyntax-By-Example#Cleaning-Up-The-Syntax-Tree":{"title":"Cleaning Up The Syntax Tree","url":"\/tutorials\/swiftsyntax\/swiftsyntax-by-example#Cleaning-Up-The-Syntax-Tree","type":"section","role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/com.apple.swift-syntax\/tutorials\/SwiftSyntax\/SwiftSyntax-By-Example#Cleaning-Up-The-Syntax-Tree","abstract":[{"type":"text","text":"In this tutorial you’ll explore the SwiftSyntax API by writing a tool"},{"type":"text","text":" "},{"type":"text","text":"that formats and sorts the import statements in a Swift file."}]},"Formatter.step7.swift":{"fileType":"swift","type":"file","highlights":[{"line":30},{"line":31},{"line":32},{"line":33},{"line":34},{"line":35},{"line":36},{"line":37}],"identifier":"Formatter.step7.swift","fileName":"importformatter.swift","content":["import Foundation","import SwiftParser","import SwiftSyntax","","@main struct ImportFormatter {","  static func main() {","    guard CommandLine.arguments.count == 2 else {","      print(\"Not enough arguments!\")","      return","    }","","    let filePath = CommandLine.arguments[1]","    guard FileManager.default.fileExists(atPath: filePath) else {","      print(\"File doesn't exist at path: \\(filePath)\")","      return","    }","","    guard let file = try? String(contentsOfFile: filePath) else {","      print(\"File at path isn't readable: \\(filePath)\")","      return","    }","","    let formattedFile = ImportFormatter().formatImports(in: file)","    print(formattedFile)","  }","","  func formatImports(in file: String) -> SourceFileSyntax {","    let sourceFile = Parser.parse(source: file)","    var items = classifyItems(in: sourceFile)","    let pivotPoint = items.partition { item in","      switch item {","      case .import(_, _):","        return false","      case .other(_):","        return true","      }","    }","    return sourceFile","  }","","  enum Item {","    case `import`(ImportDeclSyntax, CodeBlockItemSyntax)","    case other(CodeBlockItemSyntax)","  }","","  func classifyItems(in file: SourceFileSyntax) -> [Item] {","    file","      .statements","      .map { statement in","        if case .decl(let decl) = statement.item,","          let `import` = decl.as(ImportDeclSyntax.self)","        {","          return .import(`import`, statement)","        } else {","          return .other(statement)","        }","      }","  }","}"],"syntax":"swift"},"doc://com.apple.swift-syntax/tutorials/Tutorial-Table-of-Contents":{"type":"topic","kind":"overview","role":"overview","abstract":[{"type":"text","text":"SwiftSyntax provides the foundation for tools that inspect, manipulate,"},{"type":"text","text":" "},{"type":"text","text":"and transform Swift source code."}],"identifier":"doc:\/\/com.apple.swift-syntax\/tutorials\/Tutorial-Table-of-Contents","title":"Introduction to SwiftSyntax","url":"\/tutorials\/tutorial-table-of-contents"},"Formatter.step8.swift":{"type":"file","highlights":[{"line":38},{"line":39},{"line":40},{"line":41},{"line":42},{"line":43},{"line":44},{"line":45},{"line":46},{"line":47}],"fileName":"importformatter.swift","content":["import Foundation","import SwiftParser","import SwiftSyntax","","@main struct ImportFormatter {","  static func main() {","    guard CommandLine.arguments.count == 2 else {","      print(\"Not enough arguments!\")","      return","    }","","    let filePath = CommandLine.arguments[1]","    guard FileManager.default.fileExists(atPath: filePath) else {","      print(\"File doesn't exist at path: \\(filePath)\")","      return","    }","","    guard let file = try? String(contentsOfFile: filePath) else {","      print(\"File at path isn't readable: \\(filePath)\")","      return","    }","","    let formattedFile = ImportFormatter().formatImports(in: file)","    print(formattedFile)","  }","","  func formatImports(in file: String) -> SourceFileSyntax {","    let sourceFile = Parser.parse(source: file)","    var items = classifyItems(in: sourceFile)","    let pivotPoint = items.partition { item in","      switch item {","      case .import(_, _):","        return false","      case .other(_):","        return true","      }","    }","    items[..<pivotPoint]","      .sort { lhs, rhs in","        guard","          case let .import(lhsImport, _) = lhs,","          case let .import(rhsImport, _) = rhs","        else {","          fatalError(\"Partition must only contain import items!\")","        }","        return lhsImport.path.description < rhsImport.path.description","      }","    return sourceFile","  }","","  enum Item {","    case `import`(ImportDeclSyntax, CodeBlockItemSyntax)","    case other(CodeBlockItemSyntax)","  }","","  func classifyItems(in file: SourceFileSyntax) -> [Item] {","    file","      .statements","      .map { statement in","        if case .decl(let decl) = statement.item,","          let `import` = decl.as(ImportDeclSyntax.self)","        {","          return .import(`import`, statement)","        } else {","          return .other(statement)","        }","      }","  }","}"],"syntax":"swift","identifier":"Formatter.step8.swift","fileType":"swift"},"Package.step3.swift":{"syntax":"swift","fileName":"Package.swift","fileType":"swift","type":"file","content":["\/\/ swift-tools-version: 5.9","\/\/ The swift-tools-version declares the minimum version of Swift required to build this package.","","import PackageDescription","","let package = Package(","  name: \"importformatter\",","  products: [","    \/\/ Products define the executables and libraries a package produces, making them visible to other packages.","    .executable(","      name: \"importformatter\",","      targets: [\"importformatter\"]","    )","  ],","  dependencies: [","    \/\/ Dependencies declare other packages that this package depends on.","    .package(url: \"https:\/\/github.com\/