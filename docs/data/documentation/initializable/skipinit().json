","level":2},{"syntax":"swift","type":"codeListing","code":["@AutoAwaitInit","actor MyService: Initializable {","    let gate = InitializationGate()","","    \/\/ ✅ Skipped — this IS the initialization method","    @SkipInit","    func setup() async {","        await loadResources()","        await markInitialized()","    }","","    \/\/ ✅ Gets @WaitForInit automatically","    func fetchData() async -> Data { ... }","}"]},{"type":"heading","text":"Diagnostics","anchor":"Diagnostics","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Not async"}]},{"type":"text","text":": Emits an error with a fix-it to remove "},{"type":"codeVoice","code":"@SkipInit"},{"type":"text","text":", because"},{"type":"text","text":" "},{"type":"text","text":"synchronous methods are never stamped by "},{"type":"codeVoice","code":"@AutoAwaitInit"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"@AutoAwaitThrowingInit"},{"type":"text","text":" "},{"type":"text","text":"in the first place — the annotation is redundant."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"No enclosing "},{"type":"codeVoice","code":"@AutoAwaitInit"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"@AutoAwaitThrowingInit"}]},{"type":"text","text":": Emits an error with"},{"type":"text","text":" "},{"type":"text","text":"a fix-it to remove "},{"type":"codeVoice","code":"@SkipInit"},{"type":"text","text":", since there is nothing to skip."}]}]}]},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"This macro produces no peer declarations. It acts purely as a marker"},{"type":"text","text":" "},{"type":"text","text":"that is checked by the "},{"type":"reference","identifier":"doc:\/\/Initializable\/documentation\/Initializable\/AutoAwaitInit()","isActive":true},{"type":"text","text":" and "},{"type":"reference","iden